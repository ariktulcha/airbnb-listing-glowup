---
import '../styles/global.css';
import '../styles/blog-upgrade.css';
import '../styles/motion.css';

interface Props {
  title: string;
  description: string;
  path?: string;
  image?: string;
}

const {
  title,
  description,
  path = '/',
  image = '/images/generated/01-hero-living-room.svg'
} = Astro.props;
const siteRoot = Astro.site ?? 'https://airbnblistingglowup.com';
const canonical = new URL(path, siteRoot).toString();
const ogImage = new URL(image, siteRoot).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#17130f" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Listing Glow Studio" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1600" />
    <meta property="og:image:height" content="900" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ProfessionalService',
      name: 'Listing Glow Studio',
      description,
      areaServed: 'Worldwide',
      priceRange: '$300',
      url: canonical,
      serviceType: 'Short-term rental listing presentation transformation'
    })} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <nav class="nav" aria-label="Primary navigation">
        <a href="/" class="brand" aria-label="Listing Glow Studio home">
          <span class="brand-mark">LG</span>
          <span>Listing Glow Studio</span>
        </a>
        <div class="nav-links">
          <a href="/offer/">Offer</a>
          <a href="/process/">Process</a>
          <a href="/sample/">Sample</a>
          <a href="/growth-sprint/">Growth Sprint</a>
          <a href="/blog/">Notes</a>
          <a class="nav-cta" href="/score/">Free Listing Score</a>
        </div>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <div>
          <a href="/" class="brand"><span class="brand-mark">LG</span><span>Listing Glow Studio</span></a>
          <p class="disclaimer">We are not affiliated with Airbnb. We do not guarantee rankings, occupancy, or revenue. Photo edits are designed to make existing photos clearer and more professional, not to misrepresent the property.</p>
        </div>
        <div class="footer-links">
          <a href="/offer/">Offer</a>
          <a href="/process/">Process</a>
          <a href="/score/">Free score</a>
          <a href="/growth-sprint/">Growth Sprint</a>
          <a href="/resources/airbnb-listing-scorecard/">Scorecard</a>
          <a href="/blog/">Blog</a>
        </div>
      </div>
    </footer>
    <a class="sticky-score-cta" href="/score/" aria-label="Get a free listing score"><span>↗</span> Free score</a>
    <script is:inline>
      (() => {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const revealSelectors = [
          '.section',
          '.panel',
          '.photo-proof-card',
          '.review-card',
          '.mock-listing',
          '.blog-card',
          '.article-content',
          '.article-sidebar',
          '.lead-magnet-card',
          '.workflow-card',
          '.audit-table-card'
        ];
        const stickyCta = document.querySelector('.sticky-score-cta');
        if (reduce) {
          stickyCta?.classList.add('is-visible');
          return;
        }
        document.body.classList.add('motion-ready');
        const revealEls = Array.from(document.querySelectorAll(revealSelectors.join(',')));
        revealEls.forEach((el) => el.classList.add('reveal-on-scroll'));
        const io = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        }, { threshold: 0.14, rootMargin: '0px 0px -8% 0px' });
        revealEls.forEach((el) => io.observe(el));
        const revealInViewport = () => {
          revealEls.forEach((el) => {
            const rect = el.getBoundingClientRect();
            if (rect.top < window.innerHeight * .92 && rect.bottom > 0) el.classList.add('is-visible');
          });
        };
        requestAnimationFrame(revealInViewport);
        window.addEventListener('scroll', revealInViewport, { passive: true });
        window.setTimeout(() => {
          revealEls.forEach((el) => {
            const rect = el.getBoundingClientRect();
            if (rect.top < window.innerHeight * 1.2) el.classList.add('is-visible');
          });
        }, 700);
        const toggleSticky = () => {
          if (!stickyCta) return;
          stickyCta.classList.toggle('is-visible', window.scrollY > 680);
        };
        toggleSticky();
        window.addEventListener('scroll', toggleSticky, { passive: true });
      })();
    </script>
  </body>
</html>
