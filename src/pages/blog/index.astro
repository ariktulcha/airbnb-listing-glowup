---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadMagnetCTA from '../../components/LeadMagnetCTA.astro';
const posts = [
  { title: '10 Things to Fix Before Lowering Your Airbnb Price', tag: 'Pricing leak', excerpt: 'Before discounting your nightly rate, check whether your listing is making a decent property look average.', href: '/blog/10-things-to-fix-before-lowering-airbnb-price/' },
  { title: 'Airbnb Listing Scorecard: Grade Your Listing Before Guests Do', tag: 'Scorecard', excerpt: 'Use a simple 100-point audit to find weak photos, vague copy, missing trust signals, and pricing-positioning gaps.', href: '/blog/airbnb-listing-scorecard-grade-your-listing/' },
  { title: 'Your Airbnb Cover Photo Is the First Booking Filter', tag: 'Cover photo', excerpt: 'How to choose a cover image that earns the click without exaggerating what the guest will get.', href: '/blog/airbnb-cover-photo-first-booking-filter/' },
  { title: 'How to Order Airbnb Photos So Guests Understand the Stay', tag: 'Photo order', excerpt: 'A practical photo-sequence framework for making the first five images do the selling.', href: '/blog/how-to-order-airbnb-photos/' },
  { title: 'Airbnb Title Examples That Sell the Stay Without Sounding Fake', tag: 'Copy', excerpt: 'Turn generic listing titles into specific guest promises without hype, tricks, or keyword stuffing.', href: '/blog/airbnb-title-examples/' },
  { title: 'Why Your Airbnb Gets Views But Not Bookings', tag: 'Diagnostics', excerpt: 'Diagnose whether the issue is price, trust, presentation, guest fit, or a mismatch against competitors.', href: '/blog/why-airbnb-gets-views-but-not-bookings/' },
  { title: 'Airbnb Description Examples: From Inventory List to Guest Story', tag: 'Description', excerpt: 'Rewrite listing copy so guests understand the stay faster and feel more confident before they book.', href: '/blog/airbnb-description-examples/' },
  { title: 'Airbnb Photo Captions That Convert: What to Write Under Each Image', tag: 'Captions', excerpt: 'Photo captions can clarify bed sizes, room use, views, workspaces, and trust details that photos alone do not explain.', href: '/blog/airbnb-photo-captions-that-convert/' },
  { title: 'Airbnb Competitor Research for Hosts: Compare Presentation Before Price', tag: 'Competitors', excerpt: 'How to compare nearby listings without copying them or racing to the bottom on price.', href: '/blog/airbnb-competitor-research-for-hosts/' },
  { title: 'What an Airbnb Listing Glow-Up Preview Should Include', tag: 'Preview', excerpt: 'A good before/after preview should be useful, honest, watermarked, and specific enough for a host to trust the full service.', href: '/blog/airbnb-listing-glow-up-before-after-preview/' }
];
---
<BaseLayout title="Airbnb Listing Diagnostics Blog | Airbnb Listing Glow-Up" description="Ten practical 1,000-word guides for Airbnb hosts on photos, cover images, captions, titles, pricing leaks, competitor research, and listing conversion." path="/blog/">
  <section class="section editorial-hero">
    <div class="container">
      <p class="eyebrow">Field notes</p>
      <h1>Ten practical guides for hosts who want bookings, not vague marketing advice.</h1>
      <p class="lede">Every article is built around the same principle: fix the visible reasons good properties look weaker than they are before you discount, panic, or blame the algorithm.</p>
      <div class="hero-actions">
        <a class="button primary" href="/resources/airbnb-listing-scorecard/">Get the lead magnet</a>
        <a class="button secondary" href="/score/">Request a free score</a>
      </div>
    </div>
  </section>
  <section class="section compact">
    <div class="container blog-grid">
      {posts.map((post, index) => (
        <a class="blog-card" href={post.href}>
          <div class="blog-thumb"><span>{String(index + 1).padStart(2, '0')}</span></div>
          <div>
            <span class="tag">{post.tag}</span>
            <h3>{post.title}</h3>
            <p>{post.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
  <LeadMagnetCTA eyebrow="Lead magnet" title="Download the Airbnb Listing Scorecard" text="Use the 100-point self-audit to spot weak cover images, bad sequencing, vague copy, missing captions, and pricing-positioning mismatches before lowering your nightly rate." />
</BaseLayout>
