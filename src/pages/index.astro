---
import BaseLayout from '../layouts/BaseLayout.astro';
import OfferCard from '../components/OfferCard.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import LeadMagnetCTA from '../components/LeadMagnetCTA.astro';
---
<BaseLayout title="Airbnb Listing Glow-Up | $300 listing transformation for hosts" description="A premium $300 Airbnb and short-term-rental listing transformation: photos, cover image, photo order, copy, captions, reel, pricing note, and top 10 fixes." path="/">
  <section class="hero">
    <div class="container grid two-col">
      <div class="hero-copy">
        <p class="eyebrow">For under-presented short-term rentals</p>
        <h1>Your Airbnb may not need a better property. <span class="kicker">It may need a better presentation.</span></h1>
        <p class="lede">We turn weak Airbnb listings into sharper, more professional guest-facing presentations — better photos, stronger cover image, smarter photo order, paste-ready copy, captions, a 30-second vertical reel, and a clear action plan.</p>
        <div class="hero-actions">
          <a class="button primary" href="/score/">Get a free listing score</a>
          <a class="button secondary" href="/sample/">See sample glow-up</a>
        </div>
        <p class="fineprint">No fake edits. No ranking promises. No “AI copywriting” commodity package — this is a full listing presentation transformation.</p>
      </div>
      <aside class="diagnostic-card" aria-label="Listing diagnosis example">
        <div class="browser-bar"><span></span><span></span><span></span></div>
        <div class="card-photo"></div>
        <div class="score">
          <div class="score-number">62</div>
          <p><strong>Presentation score</strong><br />Good property signal, weak first impression. Biggest revenue leak: cover photo + photo sequence.</p>
        </div>
        <ul class="checklist">
          <li>Replace cover with brightest lifestyle-forward image</li>
          <li>Move kitchen and workspace before corridor photos</li>
          <li>Rewrite title around guest use case, not square footage</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container grid two-col">
      <div>
        <p class="eyebrow">The problem</p>
        <h2>Your listing is being judged before guests read the details.</h2>
      </div>
      <div class="panel">
        <p>Many hosts have good apartments hidden behind dark photos, a generic title, random photo order, and descriptions that read like inventory lists. Guests compare your listing against polished competitors in seconds.</p>
        <p><strong>We do not sell magic occupancy promises.</strong> We fix the presentation gaps that make a real property look less desirable than it is.</p>
      </div>
    </div>
  </section>

  <section class="section compact">
    <div class="container">
      <OfferCard />
    </div>
  </section>

  <section class="section">
    <div class="container grid two-col">
      <div>
        <p class="eyebrow">Sample concept</p>
        <h2>From “nice apartment” to a clearer reason to book.</h2>
        <p class="lede">The glow-up is not about pretending the property is something else. It is about helping guests see the strongest version of what already exists.</p>
        <a class="button secondary" href="/sample/">View the sample breakdown</a>
      </div>
      <BeforeAfter />
    </div>
  </section>

  <section class="section compact">
    <div class="container grid three-col">
      <article class="panel">
        <div class="number">01</div>
        <h3>Visual diagnosis</h3>
        <p>Cover image, photo quality, sequence, redundant shots, missing trust details, and room-by-room story.</p>
      </article>
      <article class="panel">
        <div class="number">02</div>
        <h3>Guest positioning</h3>
        <p>Why this stay, for whom, and why it feels like the better choice than nearby competitors.</p>
      </article>
      <article class="panel">
        <div class="number">03</div>
        <h3>Airbnb-ready output</h3>
        <p>Paste-ready title, description, captions, action list, reel file direction, and competitor/pricing note.</p>
      </article>
    </div>
  </section>

  <LeadMagnetCTA />
</BaseLayout>
