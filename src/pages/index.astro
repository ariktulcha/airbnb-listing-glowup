---
import BaseLayout from '../layouts/BaseLayout.astro';
import OfferCard from '../components/OfferCard.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import LeadMagnetCTA from '../components/LeadMagnetCTA.astro';

const iconCards = [
  { icon: '⌁', title: 'Cover photo', text: 'Choose the strongest first-click image and crop it like an ad, not a folder thumbnail.' },
  { icon: '▦', title: 'Photo order', text: 'Turn random rooms into a fast visual story guests understand in the first five images.' },
  { icon: '✎', title: 'Copy + captions', text: 'Rewrite titles, descriptions, and photo captions around guest clarity and booking confidence.' },
  { icon: '◎', title: 'Competitor lens', text: 'Compare the listing against nearby options before guessing that price is the only problem.' }
];

const photoMoments = [
  ['/images/photos/host-dining-room.jpg', 'Trust starts with rooms that look real, clean, and specific.', 'Cover-photo choice'],
  ['/images/photos/apartment-kitchen.jpg', 'Practical spaces need captions so guests understand what they can actually use.', 'Caption clarity'],
  ['/images/photos/apartment-balcony.jpg', 'Small lifestyle signals can make the stay feel more bookable than another generic unit.', 'Guest positioning']
];

const trustCards = [
  ['No fake results', 'We do not promise rankings, occupancy, revenue, or algorithm hacks. The offer improves presentation quality and guest clarity.'],
  ['No misleading edits', 'Photos should be brighter, straighter, cleaner, and better ordered — not fake, enlarged, or materially changed.'],
  ['Preview before payment', 'The host sees a watermarked sample diagnosis first, so the sale is based on visible value, not pressure.']
];

const reviewCards = [
  ['Pilot host feedback', '“The audit made the listing feel clearer, more premium, and much easier for guests to understand.”'],
  ['Review line to earn', '“I finally understood why people were viewing the listing but not choosing it.”'],
  ['Review line to earn', '“The new photo order and captions made the stay feel more trustworthy without exaggerating anything.”']
];
---
<BaseLayout title="Listing Glow Studio | $300 Airbnb listing transformation for hosts" description="Listing Glow Studio is a premium $300 Airbnb and short-term-rental listing transformation: photos, cover image, photo order, copy, captions, reel, pricing note, and top 10 fixes." path="/" image="/images/blog/airbnb-listing-scorecard-grade-your-listing.svg">
  <section class="hero hero-upgraded trust-hero">
    <div class="container grid two-col hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Listing Glow Studio · for good properties with weak presentation</p>
        <h1>Make a decent stay look trustworthy enough to choose.</h1>
        <p class="lede">A human-reviewed Airbnb listing transformation: stronger cover photo, better photo order, honest enhancement, clearer copy, useful captions, competitor context, and a paste-ready delivery file.</p>
        <div class="hero-actions">
          <a class="button primary" href="/score/">Get a free listing score</a>
          <a class="button secondary" href="/sample/">See sample audit</a>
        </div>
        <div class="proof-strip" aria-label="Service proof points">
          <span>$300 fixed package</span>
          <span>Watermarked preview first</span>
          <span>No fake edits or booking promises</span>
        </div>
      </div>
      <aside class="audit-screenshot-card" aria-label="Mock listing audit screenshot">
        <div class="browser-bar"><span></span><span></span><span></span></div>
        <div class="audit-photo-frame">
          <img src="/images/photos/host-dining-room.jpg" alt="Credible apartment living room used as a mock listing cover photo" loading="eager" />
          <span class="watermark">MOCK PREVIEW</span>
        </div>
        <div class="audit-score-row">
          <div class="score-number">62</div>
          <p><strong>Presentation score</strong><br />Good property signal, weak first impression. Biggest leak: cover photo + first five photo sequence.</p>
        </div>
        <ul class="checklist">
          <li>Use a bright, lifestyle-forward image as cover</li>
          <li>Move bedroom, workspace, and balcony before corridor photos</li>
          <li>Rewrite title around guest use case, not generic adjectives</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section compact trust-strip-section">
    <div class="container stat-row">
      <div><strong>10–20</strong><span>photos enhanced and ordered</span></div>
      <div><strong>3</strong><span>title options</span></div>
      <div><strong>30s</strong><span>vertical reel plan</span></div>
      <div><strong>10</strong><span>highest-impact fixes</span></div>
    </div>
  </section>

  <section class="section compact icon-system-section">
    <div class="container grid four-col">
      {iconCards.map((card) => (
        <article class="panel icon-card">
          <div class="line-icon" aria-hidden="true">{card.icon}</div>
          <h3>{card.title}</h3>
          <p>{card.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section photo-proof-section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Where credibility comes from</p>
        <h2>Use real-looking listing moments, not abstract AI graphics.</h2>
        <p class="lede">Hosts need to feel that we understand their actual problem: the property may be fine, but the presentation is not earning enough trust in the first few seconds.</p>
      </div>
      <div class="photo-proof-grid">
        {photoMoments.map(([src, text, label]) => (
          <figure class="photo-proof-card">
            <img src={src} alt={text} loading="eager" />
            <figcaption><span>{label}</span>{text}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid two-col">
      <div>
        <p class="eyebrow">The real problem</p>
        <h2>Guests judge your stay before they understand your property.</h2>
      </div>
      <div class="panel large-copy">
        <p>Many hosts own decent properties but present them like afterthoughts: dark cover photos, random room order, generic titles, empty captions, and descriptions that read like inventory lists. In a crowded market, that makes a real property feel less valuable than nearby competitors.</p>
        <p><strong>This is not “ChatGPT Airbnb copywriting.”</strong> The product is a complete listing presentation upgrade: visual diagnosis, honest photo improvement, copy, order, captions, competitor context, and a paste-ready delivery file.</p>
      </div>
    </div>
  </section>

  <section class="section compact">
    <div class="container"><OfferCard /></div>
  </section>

  <section class="section compact founder-section founder-section-upgraded">
    <div class="container grid two-col founder-grid">
      <div class="founder-photo-wrap founder-photo-card">
        <img src="/images/arik-airbnb-glowup-founder.png" alt="Arik, founder of Listing Glow Studio, in a styled short-term-rental living room" class="founder-photo" loading="eager" />
        <div class="founder-badge">Human review layer</div>
      </div>
      <div class="panel founder-copy founder-trust-copy">
        <p class="eyebrow">Arik · Listing Doctor</p>
        <h2>The trust layer is the product.</h2>
        <p>AI can generate copy. A host does not need another generic paragraph. The valuable part is judgment: which photo should lead, what guests need to understand first, what feels misleading, what feels weak, and what should change before lowering price.</p>
        <div class="signature-card">
          <strong>Operating rule:</strong>
          <span>Make the listing clearer and more professional without misrepresenting the property.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section screenshot-section">
    <div class="container grid two-col">
      <div>
        <p class="eyebrow">Screenshots that should exist</p>
        <h2>Show the deliverable, not just the promise.</h2>
        <p class="lede">The sales page needs mock screenshots of the actual process: audit score, reordered gallery, rewritten copy, and final delivery file. These are safer than taking real Airbnb screenshots and more convincing than abstract graphics.</p>
      </div>
      <div class="deliverable-mockup">
        <div class="browser-bar"><span></span><span></span><span></span></div>
        <div class="delivery-row"><strong>Cover photo</strong><span>Replace dark sofa photo with bright living-room image</span></div>
        <div class="delivery-row"><strong>Photo order</strong><span>01 living room · 02 bedroom · 03 kitchen · 04 balcony · 05 workspace</span></div>
        <div class="delivery-row"><strong>Title option</strong><span>Sunlit design stay near cafés + metro</span></div>
        <div class="delivery-row"><strong>Top fix</strong><span>Add captions for bed size, stairs, parking, noise, and workspace</span></div>
      </div>
    </div>
  </section>

  <section class="section testimonials-section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Client proof section</p>
        <h2>Use honest review-style proof — never fake guarantees.</h2>
        <p class="lede">Until there are real paid clients, keep this clearly positioned as pilot/sample feedback. Once a host pays, replace these with real names, property type, and before/after details.</p>
      </div>
      <div class="review-grid">
        {reviewCards.map(([label, quote]) => (
          <article class="review-card">
            <div class="stars">★★★★★</div>
            <p>{quote}</p>
            <span>{label}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid two-col">
      <div>
        <p class="eyebrow">Preview before purchase</p>
        <h2>A useful watermarked before/after, not a creepy sales trick.</h2>
        <p class="lede">The preview should show enough real value to trust the service: a better cover candidate, sample title direction, photo-order issues, and a few top fixes. It should not fake amenities or promise guaranteed revenue.</p>
        <a class="button secondary" href="/sample/">View sample breakdown</a>
      </div>
      <BeforeAfter />
    </div>
  </section>

  <section class="section compact trust-cards-section">
    <div class="container grid three-col">
      {trustCards.map(([title, text]) => (
        <article class="panel feature-panel trust-card"><div class="number">✓</div><h3>{title}</h3><p>{text}</p></article>
      ))}
    </div>
  </section>

  <LeadMagnetCTA />
</BaseLayout>
