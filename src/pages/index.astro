---
import BaseLayout from '../layouts/BaseLayout.astro';
import OfferCard from '../components/OfferCard.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import LeadMagnetCTA from '../components/LeadMagnetCTA.astro';

const iconCards = [
  { icon: '⍁', title: 'Cover photo', text: 'Choose the strongest first-click image and crop it like an ad, not a folder thumbnail.' },
  { icon: '▦', title: 'Photo order', text: 'Turn random rooms into a fast visual story guests understand in the first five images.' },
  { icon: '✎', title: 'Copy + captions', text: 'Rewrite titles, descriptions, and photo captions around guest clarity and booking confidence.' },
  { icon: '◎', title: 'Competitor lens', text: 'Compare the listing against nearby options before guessing that price is the only problem.' }
];

const photoMoments = [
  ['/images/photos/host-dining-room.jpg', 'Trust starts with rooms that look real, clean, and specific.', 'Cover-photo choice'],
  ['/images/photos/apartment-kitchen.jpg', 'Practical spaces need captions so guests understand what they can actually use.', 'Caption clarity'],
  ['/images/photos/apartment-balcony.jpg', 'Small lifestyle signals can make the stay feel more bookable than another generic unit.', 'Guest positioning']
];

const trustCards = [
  ['No fake results', 'I do not promise rankings, occupancy, revenue, or algorithm hacks. I improve presentation quality and guest clarity.'],
  ['No misleading edits', 'I make photos brighter, straighter, cleaner, and better ordered — not fake, enlarged, or materially changed.'],
  ['Preview before payment', 'I send a watermarked sample diagnosis first, so the sale is based on visible value, not pressure.']
];

const reviewCards = [
  ['Athens', 'Nikos P.', 'Property manager', 'male', 'NP', '“The audit made the apartment feel clearer and more premium without pretending it was something else.”'],
  ['Athens', 'Dimitris K.', 'Host', 'male', 'DK', '“I finally understood why the first five photos were confusing guests. The new order made the stay easier to imagine.”'],
  ['Athens', 'Eleni M.', 'Co-host', 'female', 'EM', '“The cover-photo advice was simple, practical, and immediately made the listing feel more professional.”'],
  ['Paris', 'Julien R.', 'Short-term rental operator', 'male', 'JR', '“The copy stopped sounding generic and started explaining the actual guest experience.”'],
  ['Paris', 'Marc L.', 'Independent host', 'male', 'ML', '“I liked that the recommendations were specific: what to move, what to rewrite, and what not to exaggerate.”'],
  ['Madrid', 'Carlos S.', 'Host', 'male', 'CS', '“Before lowering the price, this showed me how much the presentation itself could be improved.”'],
  ['Rome', 'Sofia B.', 'Apartment host', 'female', 'SB', '“The final action list was clear enough that I could update the listing without another strategy call.”']
];

const workflowSteps = [
  ['01', 'Score the leak', 'I grade the cover photo, first five photos, title, captions, description, and competitor context before touching the listing.'],
  ['02', 'Create the preview', 'I use a watermarked before/after to show enough value to trust the service without pressure or fake guarantees.'],
  ['03', 'Deliver paste-ready', 'I send a final file the host can copy into the listing: photos, order, titles, captions, copy, reel notes, and top fixes.']
];

const auditRows = [
  ['Cover photo', 'Weak first impression', 'Use bright living-room angle with table styling'],
  ['First 5 photos', 'Random room order', 'Living → bedroom → kitchen → balcony → workspace'],
  ['Title', 'Generic adjectives', 'Lead with guest use case + location trigger'],
  ['Captions', 'Mostly missing', 'Explain bed size, stairs, parking, noise, workspace']
];

const personaMoments = [
  ['/images/persona/ryan-laptop.jpg', 'Reviewing a listing', 'Cover photo + copy diagnosis, start to finish.'],
  ['/images/persona/ryan-tablet-before-after.jpg', 'Before/after walkthrough', 'Showing a host exactly what changes and why.'],
  ['/images/persona/ryan-founder-portrait.jpg', 'Ryan Ashford', 'Listing transformation specialist, working with hosts directly.']
];
---
<BaseLayout title="Listing Glow Studio | $300 Airbnb listing transformation for hosts" description="Listing Glow Studio is a premium $300 Airbnb and short-term-rental listing transformation: photos, cover image, photo order, copy, captions, reel, pricing note, and top 10 fixes." path="/" image="/images/persona/ryan-founder-portrait.jpg">
  <section class="hero hero-upgraded trust-hero">
    <div class="container grid two-col hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Listing Glow Studio · conversion audit for short-term rentals</p>
        <h1>Turn a forgettable rental listing into a stay guests trust in seconds.</h1>
        <p class="lede">I personally review and upgrade Airbnb listings for hosts who have a good property but weak presentation: stronger cover photo, better photo order, honest enhancement, clearer copy, useful captions, competitor context, and a paste-ready delivery file.</p>
        <div class="hero-actions">
          <a class="button primary" href="/score/">Get a free listing score</a>
          <a class="button secondary" href="/sample/">See sample audit</a>
        </div>
        <div class="proof-strip" aria-label="Service proof points">
          <span>$300 fixed package</span>
          <span>Watermarked preview first</span>
          <span>No fake edits or booking promises</span>
        </div>
        <div class="hero-mini-proof">
          <span>Built like a listing audit</span>
          <span>Reviewed like a hospitality page</span>
          <span>Delivered like a sales asset</span>
        </div>
        <figure class="persona-hero-portrait" style="max-width: 220px; margin-top: 30px;">
          <img src="/images/persona/ryan-selfie-thumb.jpg" alt="Ryan Ashford, listing transformation specialist" loading="eager" />
          <figcaption><strong>Ryan Ashford</strong><span>Listing transformation specialist</span></figcaption>
        </figure>
      </div>
      <aside class="audit-screenshot-card" aria-label="Mock listing audit screenshot">
        <div class="browser-bar"><span></span><span></span><span></span></div>
        <div class="audit-photo-frame">
          <img src="/images/photos/host-dining-room.jpg" alt="Credible apartment living room used as a mock listing cover photo" loading="eager" />
          <span class="watermark">MOCK PREVIEW</span>
        </div>
        <div class="audit-score-row">
          <div class="score-number">62</div>
          <p><strong>Presentation score</strong><br />Good property signal, weak first impression. Biggest leak: cover photo + first five photo sequence.</p>
        </div>
        <div class="audit-meter" aria-hidden="true"><span style="width: 62%"></span></div>
        <div class="audit-tags"><span>Cover leak</span><span>Photo order</span><span>Title weak</span></div>
        <ul class="checklist">
          <li>Use a bright, lifestyle-forward image as cover</li>
          <li>Move bedroom, workspace, and balcony before corridor photos</li>
          <li>Rewrite title around guest use case, not generic adjectives</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section compact trust-strip-section">
    <div class="container stat-row">
      <div><strong>10–20</strong><span>photos enhanced and ordered</span></div>
      <div><strong>3</strong><span>title options</span></div>
      <div><strong>30s</strong><span>vertical reel plan</span></div>
      <div><strong>10</strong><span>highest-impact fixes</span></div>
    </div>
  </section>

  <section class="section conversion-spine-section">
    <div class="container">
      <div class="section-head split-head">
        <div>
          <p class="eyebrow">Conversion spine</p>
          <h2>A clear path from “bad listing” to “I can trust this stay.”</h2>
        </div>
        <p class="lede">My process is simple: I diagnose the leak, show a concrete preview, then deliver a finished listing kit the host can actually use.</p>
      </div>
      <div class="workflow-rail">
        {workflowSteps.map(([num, title, text]) => (
          <article class="workflow-card">
            <span>{num}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section audit-table-section">
    <div class="container grid two-col">
      <div>
        <p class="eyebrow">What the host sees</p>
        <h2>A more concrete preview makes the $300 feel real.</h2>
        <p class="lede">Instead of saying “I improve your listing” vaguely, I show the exact decision points: what is weak, what changes, and why the change helps the guest decide faster.</p>
      </div>
      <div class="audit-table-card">
        <div class="audit-table-head"><span>Listing leak</span><span>Current</span><span>Upgrade direction</span></div>
        {auditRows.map(([area, before, after]) => (
          <div class="audit-table-row"><strong>{area}</strong><span>{before}</span><span>{after}</span></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section compact icon-system-section">
    <div class="container grid four-col">
      {iconCards.map((card) => (
        <article class="panel icon-card">
          <div class="line-icon" aria-hidden="true">{card.icon}</div>
          <h3>{card.title}</h3>
          <p>{card.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section photo-proof-section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Where credibility comes from</p>
        <h2>Real listing moments, not stock photography.</h2>
        <p class="lede">I built this around the problem I keep seeing: the property may be fine, but the presentation is not earning enough trust in the first few seconds.</p>
      </div>
      <div class="photo-proof-grid">
        {photoMoments.map(([src, text, label]) => (
          <figure class="photo-proof-card">
            <img src={src} alt={text} loading="eager" />
            <figcaption><span>{label}</span>{text}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid two-col">
      <div>
        <p class="eyebrow">The real problem</p>
        <h2>Guests judge your stay before they understand your property.</h2>
      </div>
      <div class="panel large-copy">
        <p>Many hosts own decent properties but present them like afterthoughts: dark cover photos, random room order, generic titles, empty captions, and descriptions that read like inventory lists. In a crowded market, that makes a real property feel less valuable than nearby competitors.</p>
        <p><strong>This is not “ChatGPT Airbnb copywriting.”</strong> I deliver a complete listing presentation upgrade: visual diagnosis, honest photo improvement, copy, order, captions, competitor context, and a paste-ready delivery file.</p>
      </div>
    </div>
  </section>

  <section class="section compact">
    <div class="container"><OfferCard /></div>
  </section>

  <section class="section compact founder-section founder-section-upgraded">
    <div class="container grid two-col founder-grid">
      <div class="founder-photo-wrap founder-photo-card">
        <img src="/images/persona/ryan-founder-portrait.jpg" alt="Ryan Ashford, founder of Listing Glow Studio, in a bright rental apartment" class="founder-photo" loading="eager" />
        <div class="founder-badge">Human review layer</div>
      </div>
      <div class="panel founder-copy founder-trust-copy">
        <p class="eyebrow">Ryan Ashford · Listing Transformation Specialist</p>
        <p class="founder-quote">"Your Airbnb may not need a better property. It may need a better presentation."</p>
        <p>I review listings for a living — marketing, hospitality, photography, and guest psychology, all pointed at one page. AI can generate copy. A host does not need another generic paragraph. The valuable part is judgment: which photo should lead, what guests need to understand first, what feels weak, and what should change before lowering price.</p>
        <div class="signature-card">
          <strong>Operating rule:</strong>
          <span>Make the listing clearer and more professional without misrepresenting the property.</span>
        </div>
        <div class="trust-badge-row">
          <span>Practical, not theoretical</span>
          <span>No misleading edits</span>
          <span>Works directly with hosts</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section persona-strip-section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Behind the work</p>
        <h2>See more listing breakdowns.</h2>
        <p class="lede">I post short, practical teardowns of real listing mistakes — cover photos, photo order, captions, and titles — across Instagram and TikTok.</p>
      </div>
      <div class="persona-strip">
        {personaMoments.map(([src, title, text]) => (
          <figure class="persona-strip-card">
            <img src={src} alt={title} loading="eager" />
            <figcaption><strong>{title}</strong>{text}</figcaption>
          </figure>
        ))}
      </div>
      <div class="channel-row">
        <span class="channel-pill"><span class="dot"></span>Instagram — listing teardowns</span>
        <span class="channel-pill"><span class="dot"></span>TikTok — quick fixes</span>
        <span class="channel-pill"><span class="dot"></span>Facebook — host discussions</span>
      </div>
    </div>
  </section>

  <section class="section screenshot-section">
    <div class="container grid two-col">
      <div>
        <p class="eyebrow">The delivery</p>
        <h2>What actually lands in your inbox.</h2>
        <p class="lede">Every glow-up I deliver is concrete: audit score, reordered gallery, rewritten copy, and a paste-ready delivery file — not a vague promise.</p>
      </div>
      <div class="deliverable-mockup">
        <div class="browser-bar"><span></span><span></span><span></span></div>
        <div class="delivery-row"><strong>Cover photo</strong><span>Replace dark sofa photo with bright living-room image</span></div>
        <div class="delivery-row"><strong>Photo order</strong><span>01 living room · 02 bedroom · 03 kitchen · 04 balcony · 05 workspace</span></div>
        <div class="delivery-row"><strong>Title option</strong><span>Sunlit design stay near cafés + metro</span></div>
        <div class="delivery-row"><strong>Top fix</strong><span>Add captions for bed size, stairs, parking, noise, and workspace</span></div>
      </div>
    </div>
  </section>

  <section class="section story-section">
    <div class="container grid two-col">
      <div>
        <p class="eyebrow">My story</p>
        <h2>How I started seeing Airbnb listings like conversion pages.</h2>
      </div>
      <div class="panel large-copy story-card">
        <p>I started this because I kept noticing the same pattern: many hosts had good apartments, decent locations, and real hospitality — but the listing made the stay feel average.</p>
        <p>The first photo was not the strongest image. The best room was hidden too late. Titles sounded generic. Descriptions listed square meters before helping the guest imagine the trip. Hosts were thinking about price, while the bigger leak was often presentation.</p>
        <p>So I built Listing Glow Studio around one practical idea: before a host lowers the price or blames the algorithm, I help them make the listing clearer, more trustworthy, and more guest-focused.</p>
      </div>
    </div>
  </section>

  <section class="section testimonials-section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Host feedback</p>
        <h2>Seven review-style reactions I’m building toward.</h2>
        <p class="lede">I will not fake customer proof. These are clearly marked example review formats for the first Athens, Paris, Madrid, and Rome hosts — real names, photos, and verified reviews should replace them as soon as actual clients approve testimonials.</p>
      </div>
      <div class="review-grid review-grid-expanded">
        {reviewCards.map(([city, name, role, gender, initials, quote]) => (
          <article class="review-card review-card-person">
            <div class="review-person-row">
              <div class:list={["review-avatar", gender]}>{initials}</div>
              <div><strong>{name}</strong><span>{city} · {role}</span></div>
            </div>
            <div class="stars">★★★★★</div>
            <p>{quote}</p>
            <small>Example review placeholder — replace with verified customer permission.</small>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid two-col">
      <div>
        <p class="eyebrow">Preview before purchase</p>
        <h2>A useful watermarked before/after, not a creepy sales trick.</h2>
        <p class="lede">My preview shows enough real value to trust the service: a better cover candidate, sample title direction, photo-order issues, and a few top fixes. I do not fake amenities or promise guaranteed revenue.</p>
        <a class="button secondary" href="/sample/">View sample breakdown</a>
      </div>
      <BeforeAfter />
    </div>
  </section>

  <section class="section compact trust-cards-section">
    <div class="container grid three-col">
      {trustCards.map(([title, text]) => (
        <article class="panel feature-panel trust-card"><div class="number">✓</div><h3>{title}</h3><p>{text}</p></article>
      ))}
    </div>
  </section>

  <LeadMagnetCTA />
</BaseLayout>