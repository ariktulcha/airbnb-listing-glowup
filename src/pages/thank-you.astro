---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Listing received | Airbnb Listing Glow-Up" description="Thanks for requesting a free Airbnb listing score." path="/thank-you/">
  <section class="section editorial-hero">
    <div class="container narrow">
      <p class="eyebrow">Request received</p>
      <h1>Thanks — Ryan has your request.</h1>
      <p class="lede">If Resend is configured, you will also get a confirmation email from Ryan@listingglowstudio.com. If not, the request is still captured in Netlify Function logs so no lead disappears silently.</p>
      <div class="hero-actions">
        <a class="button primary" href="/resources/airbnb-listing-scorecard/">Read the scorecard</a>
        <a class="button secondary" href="/blog/">Read the blog</a>
      </div>
    </div>
  </section>
</BaseLayout>
