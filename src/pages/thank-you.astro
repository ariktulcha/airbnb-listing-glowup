---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Listing received | Airbnb Listing Glow-Up" description="Thanks for requesting a free Airbnb listing score." path="/thank-you/">
  <section class="section editorial-hero">
    <div class="container narrow">
      <p class="eyebrow">Listing received</p>
      <h1>Thanks — your listing score request is in.</h1>
      <p class="lede">The next operational step is to connect Resend so this request triggers an email notification and a simple follow-up sequence. For now, the live form route is verified and submissions are visible in Netlify Function logs.</p>
      <div class="hero-actions">
        <a class="button primary" href="/resources/airbnb-listing-scorecard/">Read the scorecard</a>
        <a class="button secondary" href="/blog/">Read the blog</a>
      </div>
    </div>
  </section>
</BaseLayout>
