---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OfferCard from '../../components/OfferCard.astro';
import LeadMagnetCTA from '../../components/LeadMagnetCTA.astro';
---
<BaseLayout title="The $300 Full Listing Glow-Up | Airbnb Listing Glow-Up" description="What is included in the $300 Airbnb Listing Glow-Up: enhanced photos, cover image, ordering, title, description, captions, reel, competitor note, and top 10 fixes." path="/offer/">
  <section class="section">
    <div class="container">
      <p class="eyebrow">The offer</p>
      <h1>Full listing transformation, not a copywriting patch.</h1>
      <p class="lede">For hosts whose listing feels weaker than the actual stay. We improve the way the property is seen, understood, and compared — using existing assets and honest presentation upgrades.</p>
    </div>
  </section>
  <section class="section compact"><div class="container"><OfferCard /></div></section>
  <section class="section">
    <div class="container grid three-col">
      <article class="panel"><h3>What changes</h3><p>Photos become clearer, the first five images carry more weight, the title has a guest-facing angle, and the description stops wasting attention.</p></article>
      <article class="panel"><h3>What does not change</h3><p>We do not add fake amenities, over-edit rooms, make misleading claims, or promise Airbnb ranking, occupancy, or revenue outcomes.</p></article>
      <article class="panel"><h3>Best fit</h3><p>Independent hosts, small property managers, and new listings with usable source photos but an unconvincing current page.</p></article>
    </div>
  </section>
  <section class="section compact">
    <div class="container panel dark">
      <p class="eyebrow">Delivery</p>
      <h2>48–72 hour turnaround after assets are received.</h2>
      <p class="lede">You receive an Airbnb-ready delivery file plus transformed visual assets and a concise decision note on the highest-impact fixes.</p>
    </div>
  </section>
  <LeadMagnetCTA />
</BaseLayout>
