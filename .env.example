# Resend email configuration for the Netlify functions.
# Copy to `.env` for local dev, and set the same vars in
# Netlify → Site settings → Environment variables for production.
#
# Without RESEND_API_KEY the forms still work and redirect to /thank-you/,
# but NO emails are sent (the functions log "resend-disabled" and skip).

# Required — your Resend API key (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — the "From" address. MUST be on a domain you've verified in
# Resend (https://resend.com/domains). Defaults to Ryan@listingglowstudio.com.
RESEND_FROM=Ryan Ashford <Ryan@listingglowstudio.com>

# Optional — where the internal "new submission" notifications go.
# Defaults to Ryan@listingglowstudio.com.
RESEND_NOTIFY_TO=Ryan@listingglowstudio.com

# Optional — reply-to address on the confirmation emails customers receive.
# Defaults to Ryan@listingglowstudio.com.
RESEND_REPLY_TO=Ryan@listingglowstudio.com
